@model ToDoApp.Core.DTOs.Auth.RegisterDto

@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-7 col-lg-6">
        <div class="glass-card">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus" style="font-size: 3rem; color: #764ba2;"></i>
                <h2 class="fw-bold mt-2">Create an Account</h2>
                <p class="text-muted">Join us and start organizing your tasks</p>
            </div>

            <form asp-controller="Auth" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control form-control-modern" placeholder="First Name" />
                            <label asp-for="Name">First Name</label>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Surname" class="form-control form-control-modern" placeholder="Last Name" />
                            <label asp-for="Surname">Last Name</label>
                            <span asp-validation-for="Surname" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control form-control-modern" placeholder="name@example.com" />
                    <label asp-for="Email">Email address</label>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Password" type="password" class="form-control form-control-modern" placeholder="Password" />
                    <label asp-for="Password">Password</label>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-4">
                    <input asp-for="PasswordConfirm" type="password" class="form-control form-control-modern" placeholder="Confirm Password" />
                    <label asp-for="PasswordConfirm">Confirm Password</label>
                    <span asp-validation-for="PasswordConfirm" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-modern w-100 py-2 mb-3">Register</button>
                
                <div class="text-center">
                    <p class="mb-0 text-muted">Already have an account? <a asp-action="Login" class="text-decoration-none fw-bold" style="color: #764ba2;">Sign in here</a></p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
