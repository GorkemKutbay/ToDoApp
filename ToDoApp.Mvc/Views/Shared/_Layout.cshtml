<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ToDoApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ToDoApp.Mvc.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm glass-nav mb-3 fixed-top">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-gradient" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-check2-square"></i> ToDoApp
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" asp-area="" asp-controller="ToDo" asp-action="GetAll">Tasks</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (!User.Identity.IsAuthenticated)
                        {
                        
                            <li class="nav-item me-3">
                                <a class="nav-link text-dark fw-medium" asp-area="" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-modern" asp-area="" asp-controller="Auth" asp-action="Register">Get Started</a>
                            </li>
                        
                        }
                        else
                        {
                            
                            <li class="nav-item">

                                <a class="btn btn-modern" asp-area="" asp-controller="Auth" asp-action="Logout">Logout</a>

                            </li>

                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container" style="padding-top: 100px;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted" style="background: transparent; border-top: 1px solid rgba(255,255,255,0.3);position:absolute;bottom:0;width:100%;height:60px;line-height:60px;">
        <div class="container text-center text-dark">
            &copy; 2026 - ToDoApp - Designed with Love
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
